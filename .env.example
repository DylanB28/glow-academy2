# Public browser configuration is stored separately in assets/supabase-config.js.
# Never expose the service-role key or Stripe secret keys in browser code.

APP_URL=https://www.gemglowacademy.com
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key
CHILD_SESSION_SECRET=replace-with-at-least-32-random-characters
MAX_CHILDREN_PER_FAMILY=3

STRIPE_TEST_MODE=true
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_WEBHOOK_SECRET_TEST=whsec_...
STRIPE_PRICE_MONTHLY_TEST=price_...
STRIPE_PRICE_ANNUAL_TEST=price_...

# Set these before switching STRIPE_TEST_MODE to false.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

RESEND_API_KEY=re_...
CONTACT_FROM_EMAIL=Gem Glow Academy <support@your-verified-domain.com>
CONTACT_TO_EMAIL=support@your-domain.com
